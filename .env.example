# ── Server ────────────────────────────────────────────
SERVER_PORT=8080
SERVER_HOST=localhost
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# ── Database ──────────────────────────────────────────
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=products
DB_USER=app
DB_PASSWORD=secret

# ── MySQL Container ───────────────────────────────────
MYSQL_ROOT_PASSWORD=secret
MYSQL_DATABASE=products
MYSQL_USER=app
MYSQL_PASSWORD=secret

# ── Elasticsearch ─────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Embedder ──────────────────────────────────────────
EMBEDDER_URL=http://localhost:8001
SENTENCE_TRANSFORMERS_HOME=/app/model-store

# ── Logger ────────────────────────────────────────────
LOG_LEVEL=info
LOG_PATH=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28

# ── Scraper ───────────────────────────────────────────
SCRAPER_ENABLED=true
SCRAPER_INTERVAL=1h
SCRAPER_TIMEOUT=30s
SCRAPER_USER_AGENT=GoRatesBot/1.0