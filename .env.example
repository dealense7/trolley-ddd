# Server
SERVER_PORT=8080
SERVER_HOST=localhost
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# Database
DATABASE_DSN=root:password@tcp(localhost:3306)/go_rates?parseTime=true&charset=utf8mb4&loc=Local

# Logger
LOG_LEVEL=info
LOG_PATH=./logs/app.log
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28

# Scraper
SCRAPER_ENABLED=true
SCRAPER_INTERVAL=1h
SCRAPER_TIMEOUT=30s
SCRAPER_USER_AGENT=GoRatesBot/1.0